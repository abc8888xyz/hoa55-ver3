      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "部署方案的话，轻量体验还想要保证安全的话用虚拟机，深度使用直接上Mac Mini，所以关于Clawdbot的教程",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
