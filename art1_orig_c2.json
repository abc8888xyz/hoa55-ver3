            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlg8GTbzChbDgMBolqvP6Lunh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "但这个bot有两个大漏勺缺点，权限极高，高到可以直接把你的电脑清空，上下文工作太烂，烧Token太快，零人敢接 Claude Opus 4.5 。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgrErXo59aegj3rhV9ZeSZgd",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "但真架不住确实太好玩了，好玩到我这两天给AI配一套完整账号，以及下单了台国补后3399的Mac Mini。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgdpQIKc5mBoHBT2xb2sVErh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "但是，目前大部分的Clawdbot的教程都停留在安装，MacMini和云服务器都不是最好的第一选择。 ",
          "style": {
            "bold": true,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "给的测试案例还都是一些通用Agent能完成的，比方说定时收集某个消息最近24小时内的变动，这个Grok的Task也能做，或者是整理文件，这个 CoWork能做，或者是做网站开发，这个Claude Code早就能做了。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
