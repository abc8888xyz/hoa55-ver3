            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgFICROrEyY218aWDMHBGRFh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "就小王这样式儿的我都懒得理他。由于我ssh接管了无头mac，并且在里面预装了claude，我直接连接它的主机，让claude看看咋回事帮我修好。比如这样，我和 claude 讲你看看它又不回我了",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgtcRNhnlxawcnMEwnkpxQWh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "然后claude直接帮我修好了",
