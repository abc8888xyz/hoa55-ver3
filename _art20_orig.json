      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "来新璐是位00后，之前自己做过 Kode agent，拆解过 Claude Code。这次他带着一个专门为直播准备的开源教学仓库 Claw 0 来，把小龙虾的技术架构一层层剥开给大家看。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlg4tF7uBOPV8y4xUNWSYAbep",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "结论很简单：",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "小龙虾 = Claude Code + 定时器 + 自己没事给自己找事干。",
          "style": {
            "bold": true,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
