      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "这次直播有个非常戏剧性的效果，中间来新璐顺手让小龙虾打了个 FaceTime 给直播间网友，折腾一阵之后真的打通了，对方直接被拉进来做了即兴连线。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
