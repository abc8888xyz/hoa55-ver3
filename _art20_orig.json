      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "另一个是直播快结束的时候，他让小龙虾\"退出飞书应用\"，结果直播就这么被龙虾亲手下播了，节目效果直接拉满。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
