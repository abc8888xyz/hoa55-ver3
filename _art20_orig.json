      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "比如 agent 可以给自己安排每天晚上12点去扫一遍某个开源仓库的 issues，然后第二天有人问它的时候，它已经提前备好资料了。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
