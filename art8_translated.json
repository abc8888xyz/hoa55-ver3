            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "Tôi có một bài hướng dẫn trước đây về cách triển khai Copaw trên máy tính Windows, nếu bạn chưa \"nuôi tôm\" có thể tự triển khai trước, nếu không biết triển khai cũng có thể bình luận",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "Hướng dẫn chi tiết cài đặt Copaw trên Windows, xây dựng tôm hùm phù hợp thể chất người Việt, tất cả các hố đã được",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "link": {
              "url": "https%3A%2F%2Fmp.weixin.qq.com%2Fs%3F__biz%3DMzkwNDcwNjMxNA%3D%3D%26mid%3D2247486800%26idx%3D1%26sn%3D5399ca99e2a8840bf55f1e9cfacd17c9%26scene%3D21%23wechat_redirect"
