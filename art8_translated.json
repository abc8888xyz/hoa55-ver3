    {
      "block_id": "doxlgoR23IgLp2aPKsyqwkDJpdg",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Trước hết nhất định phải có một con tôm hùm của riêng mình (OpenClaw, Copaw và các bản phái sinh trong nước đều được)",
