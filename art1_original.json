            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "：在飞书群里 @大总管 ：“分析一下露营折叠床的市场，并全渠道铺内容。”",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
