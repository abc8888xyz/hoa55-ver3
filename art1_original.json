      "block_type": 13,
      "block_type_name": "ordered",
      "elements": [
        {
          "type": "text_run",
          "content": "TikTok短视频生成 ",
          "style": {
            "bold": true,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "：大总管呼叫 tiktok-director 。它直接读取VOC痛点，使用Seed 2.0生成25宫格分镜。它精准设计了前2秒带“呼吸感运镜”的第一人称手持画面。它还设计了第4秒按压床垫特写，清晰展示回弹性和支撑力。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
