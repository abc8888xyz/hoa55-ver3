      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "传统的单体大模型解决不了长链路问题，容易出现“工具幻觉”。OpenClaw架构采用的是“异步状态机”逻辑，将复杂的跨境业务拆解成了流水线作业。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgLnO5hvUh8XQXM7033VqrAh",
