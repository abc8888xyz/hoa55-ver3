    {
      "block_id": "doxlgu2exKiIJsmnHndGbGlZawf",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Vừa xong, Alibaba Cloud chính thức ra mắt trọn bộ dịch vụ đám mây Moltbot (tên cũ: Clawdbot), cung cấp toàn diện tài nguyên tính toán, mô hình và ứng dụng nhắn tin cần thiết cho Agent.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "text_color": 7,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgQh39DpZdpR7jzPiCdUcDFc",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Người dùng có thể nhanh chóng kích hoạt Moltbot trên máy chủ ứng dụng nhẹ Alibaba Cloud hoặc máy tính đám mây Wuying, đồng thời gọi theo nhu cầu hơn một trăm mô hình dòng Qianwen trên Alibaba Cloud Bailian. Về kênh nhắn tin, giải pháp này không chỉ hỗ trợ ứng dụng nhắn tin iMessage, mà còn có thể tương tác qua tin nhắn DingTalk dựa trên Alibaba Cloud Computing Nest.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "text_color": 7,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgslsY1bOARfaDVZk8AlEu1g",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Hướng dẫn triển khai trên máy chủ đám mây như sau 👇",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": true,
            "strikethrough": false,
            "text_color": 7,
            "underline": false
          }
        }
      ]
    },
