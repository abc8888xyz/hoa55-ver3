      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "b. Cấu hình Bailian API Key, nhấn \"Cấu hình nhanh\", nhập API-Key của Bailian. Nhấn \"Thực thi lệnh\" để ghi API Key.",
          "style": {
