            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlg8QflkKtl3c6RHtdU5nluGh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Sau khi triển khai Moltbot, không cần mở Terminal hay bất kỳ ứng dụng client nào, chỉ cần gửi tin nhắn trực tiếp cho nó trong các cửa sổ chat hàng ngày như WhatsApp, Slack, Telegram, Moltbot sẽ bắt đầu điều phối các công cụ tương ứng để hoàn thành nhiệm vụ, giúp người dùng gọi điện, gửi tin nhắn, từ viết trang web đến triển khai trang web mua tên miền, chỉnh sửa video, chạy quảng cáo, v.v.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgfwWcNAfaOQ3Q5dF7Aoq5Ze",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Chỉ cần trò chuyện trong cửa sổ chat, Moltbot có thể giúp người dùng có được \"nhân viên AI toàn thời gian\" 7×24h. Nhờ giao diện tương tác tiện lợi và triển khai mã nguồn mở cục bộ, hiện tại Meltbot đã thu được hơn 80.000 stars trên Github.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgrMfq7eY3XLp4pROg6sI4fb",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Để đáp ứng tốt hơn trải nghiệm mô hình mạnh mẽ, phong phú và mượt mà khi nhà phát triển sử dụng Moltbot, nhiều dịch vụ mô hình trên Volcano Ark như Doubao-Seed-Code, GLM-4.7, DeepSeek-V3.2 và Kimi-K2-Thinking hiện đã tương thích hoàn toàn với hệ sinh thái kỹ thuật của nó.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
