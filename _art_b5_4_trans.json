      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Ngoài ra, không ít nhà phát triển đề cập đến vấn đề tiêu thụ Token lớn trong Moltbot, hiện nay Volcano Engine Ark Coding Plan đã chính thức hỗ trợ MoltBot.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
