      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Đăng ký gói Volcano Ark Coding Plan, nhà phát triển có thể tận hưởng engine mô hình lớn trong Moltbot: Người dùng mới tháng đầu đăng ký chỉ 9,9 nhân dân tệ (giá gốc 40 nhân dân tệ), quý đầu 60 nhân dân tệ (giá gốc 120 nhân dân tệ).",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
