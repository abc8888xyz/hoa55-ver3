      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Clawdbot 是一款开源个人助手，可以运行在本地设备上（如 Mac mini、服务器等）",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "，也可以通过集成常用的聊天软件（WhatsApp、Telegram、iMessage、Slack、Discord 等）与用户进行对话与互动。它不仅仅是一个智能聊天机器人，还是一个强大的自动化工具，能够执行任务、管理日程、处理工作内容，甚至自主学习。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
