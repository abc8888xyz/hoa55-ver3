      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Clawdbot là một trợ lý cá nhân mã nguồn mở, có thể chạy trên thiết bị cục bộ (như Mac mini, server v.v.)",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": ", cũng có thể tích hợp với các phần mềm chat phổ biến (WhatsApp, Telegram, iMessage, Slack, Discord v.v.) để trò chuyện và tương tác với người dùng. Nó không chỉ là một chatbot thông minh, mà còn là một công cụ tự động hóa mạnh mẽ, có thể thực hiện nhiệm vụ, quản lý lịch trình, xử lý công việc, thậm chí tự học.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
