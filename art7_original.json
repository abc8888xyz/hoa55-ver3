      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "在讲配置之前，先说清楚三个致命问题，不然你不知道这套方案在解决什么。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
