      "block_type": 13,
      "block_type_name": "ordered",
      "elements": [
        {
          "type": "text_run",
          "content": "交互阻塞会卡死一切。",
          "style": {
            "bold": true,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
