      "elements": [
        {
          "type": "text_run",
          "content": "时间行动今天 安装OpenClaw，写一个SOUL.md、IDENTITY.md、USER.md。挑最重复的日常任务，设置定时任务让它跑起来 3天后 开始给出具体反馈，确保反馈落入记忆文件，而不只是停留在聊天记录里 1周后 创建AGENTS.md，定义会话启动流程，添加记忆管理规则 2周后 开始写MEMORY.md，回顾每日日志，把反复出现的纠正蒸馏成永久条目。",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
