    {
      "block_id": "doxlg7JVnQUzscku4lxCYqVxYbf",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Sở thích cá nhân của tôi là dùng máy ảo trước, tiết kiệm tiền, khả năng không bị giới hạn. Máy ảo đã rất trưởng thành, chúng ta có thể cài máy ảo macOS trên Windows, Linux, Mac, sau đó mở một thư mục chia sẻ ở local để máy ảo và máy tính tương tác file, cộng thêm tài khoản riêng tôi tạo cho AI, thật sự bất bại. Còn về việc online 24 giờ, hoàn toàn có thể đợi khi nào cần thì dùng phần mềm giữ máy tính ở trạng thái thức.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgC3NJX9nAxtOWTPnDoo12Ve",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "@浮之静 ",
          "style": {
            "bold": true,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "đã viết một bài phân tích rất chi tiết về framework nền tảng của Clawdbot, giúp tôi càng chắc chắn với lựa chọn của mình. Đầu tiên là lựa chọn hệ điều hành, chọn macOS, vì nhiều dependency nền tảng của Clawdbot được phát triển dựa trên Swift,",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlg53J58WpjjPtvcpIC2bRxCg",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Về phương án triển khai, nếu muốn trải nghiệm nhẹ nhàng và đảm bảo an toàn thì dùng máy ảo, sử dụng chuyên sâu thì lên thẳng Mac Mini. Vì vậy về hướng dẫn Clawdbot",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlg9XMFIqKUVTuoTm7mHmtuPh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "tôi dự định sẽ viết ba bài. Bài này về máy ảo, máy tính local thật sự không khuyến khích dùng, cài rồi cũng không dám hỏi. Bài khác là đợi Mac mini của tôi về, cho mọi người xem phiên bản mod tối thượng, tôi đã chuẩn bị một bộ tài khoản đầy đủ cho AI (bao gồm AppleID, GoogleUltra, X...),",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
