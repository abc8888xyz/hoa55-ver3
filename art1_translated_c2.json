    {
      "block_id": "doxlg8GTbzChbDgMBolqvP6Lunh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Nhưng bot này có hai nhược điểm lớn: quyền hạn cực cao, cao đến mức có thể xóa sạch máy tính của bạn; quản lý ngữ cảnh quá tệ, đốt Token quá nhanh, không ai dám dùng Claude Opus 4.5.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgrErXo59aegj3rhV9ZeSZgd",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Nhưng thật sự không cưỡng lại được vì quá vui, vui đến mức mấy ngày nay tôi đã tạo cho AI một bộ tài khoản đầy đủ, và đặt mua một chiếc Mac Mini giá 3399 sau trợ giá.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
    {
      "block_id": "doxlgdpQIKc5mBoHBT2xb2sVErh",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Tuy nhiên, phần lớn hướng dẫn Clawdbot hiện tại đều chỉ dừng ở bước cài đặt, MacMini và cloud server đều không phải lựa chọn đầu tiên tốt nhất. ",
          "style": {
            "bold": true,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "Các ví dụ thử nghiệm đưa ra đều là những thứ Agent thông thường có thể làm được, ví dụ như thu thập định kỳ các thay đổi của một tin nhắn trong 24 giờ gần nhất - Task của Grok cũng làm được, hoặc sắp xếp file - CoWork làm được, hoặc phát triển website - Claude Code đã làm được từ lâu.",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
