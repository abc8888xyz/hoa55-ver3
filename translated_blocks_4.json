      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Cuối tuần tôi đang dùng bot, lúc đó chưa có Tiểu Vương, anh họ nó ",
          "style": {
            "bold": false,
            "inline_code": false,
