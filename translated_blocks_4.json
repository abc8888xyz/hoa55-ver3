    {
      "block_id": "doxlg9qKiSBrIuQF2CdBgXGvbfc",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Ngoài ra nó cũng có thể tự sửa chính mình. ",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        },
        {
          "type": "text_run",
          "content": "Tối qua tôi cần mở thêm một bot cho vợ, OpenClaw có nhiều chế độ chạy đa phiên, ví dụ tạo mới một profile là một cách. Điều này sẽ mở một cổng mới chạy một bộ dịch vụ mới. Bạn tự cấu hình Telegram, người khác không có Telegram thì cấu hình Lark, tài khoản độc lập với nhau.",
          "style": {
            "bold": false,
