    },
    {
      "block_id": "doxlgpkFytWiuVteOBLKD1wJMnd",
      "block_type": 2,
      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Tiểu Vương chăm chỉ chẳng khách sáo cũng chẳng gọi sếp. Trực tiếp làm luôn, tuôn ra hết không giữ lại gì. Đây là phản hồi của nó:",
          "style": {
            "bold": false,
            "inline_code": false,
            "italic": false,
            "strikethrough": false,
            "underline": false
          }
        }
      ]
    },
