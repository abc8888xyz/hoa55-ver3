      "block_type_name": "text",
      "elements": [
        {
          "type": "text_run",
          "content": "Nhìn chức năng khá nhiều, thực tế cũng đúng là không ít. Ở đây tôi chủ yếu muốn nói về heartbeat - danh sách tác vụ định thời.",
          "style": {
